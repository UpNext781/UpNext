# Server Configuration
PORT=3001
NODE_ENV=development

# Database Configuration
# Get PostgreSQL connection string from your database provider (e.g., Railway, Supabase, etc.)
# Format: postgresql://username:password@host:port/database
DATABASE_URL=your_database_url_here

# Alternative Database Configuration (if using individual params)
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=upnext_db
DB_PORT=5432

# Security Secrets
# Generate a long random string using: openssl rand -base64 32
SESSION_SECRET=your_long_random_secret_here

# Google Gemini API
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Stripe Integration
# Get your keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ElevenLabs TTS (if used)
# Get your API key from: https://elevenlabs.io/
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
